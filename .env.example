# Anthropic — required for LLM inference
ANTHROPIC_API_KEY=sk-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# TME — required for component search (get from developers.tme.eu/en/signup)
TME_APP_TOKEN=
TME_APP_SECRET=
TME_LANGUAGE=PL
TME_COUNTRY=PL

# Supabase — required for database (get from supabase.com)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...

# Redis — set REDIS_PASSWORD for production
REDIS_PASSWORD=changeme_in_production
REDIS_URL=redis://:changeme_in_production@redis:6379/0

# MinIO — internal, change passwords for production
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Observability — internal, no change needed
LOKI_URL=http://loki:3100

# Agent — internal
AGENT_MAX_CONCURRENT_TASKS=50
